# GameBox Server Environment Variables
# Copy this file to server/.env and fill in your values
# NEVER commit server/.env to version control

# Twitch API credentials (for IGDB game data)
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# DeepSeek AI (for personalized game recommendations)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Steam Web API (for Steam library import)
STEAM_API_KEY=your_steam_api_key_here

# Server port (default: 5000)
PORT=5000
